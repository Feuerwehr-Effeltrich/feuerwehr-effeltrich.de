---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  ogImage?: string;
}

const {
  title,
  description = 'Freiwillige Feuerwehr Effeltrich – Einsatzberichte, Informationen und Kontakt.',
  noindex = false,
  ogImage = '/images/FWGH.webp',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title === 'Startseite'
  ? 'Freiwillige Feuerwehr Effeltrich'
  : `${title} – Freiwillige Feuerwehr Effeltrich`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title="Feuerwehr Effeltrich – Einsätze" href="/rss.xml" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col bg-[#FAF9F7] dark:bg-[#0F0D0D] text-gray-900 dark:text-gray-100 font-sans">
    <slot name="header">
      <header class="border-b-[3px] border-brand bg-white/95 dark:bg-[#0F0D0D]/95 backdrop-blur-sm sticky top-0 z-10">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between gap-4">
          <a href="/" class="flex items-center gap-3 shrink-0 group" aria-label="Zur Startseite">
            <img
              src="/logo-lq.webp"
              alt=""
              width="42"
              height="42"
              class="w-10 h-10 object-contain transition-transform duration-200 group-hover:scale-110"
            />
            <div class="hidden sm:block leading-none">
              <span class="block text-[10px] font-bold tracking-[0.22em] uppercase text-brand">Freiwillige Feuerwehr</span>
              <span class="block text-[15px] font-bold text-gray-900 dark:text-white leading-tight tracking-tight">Effeltrich</span>
            </div>
          </a>

          <nav aria-label="Hauptnavigation" class="hidden md:flex items-center gap-7 text-sm font-medium">
            <a href="/einsaetze/" class="nav-link">Einsätze</a>
            <a href="/jugendfeuerwehr/" class="nav-link">Jugendfeuerwehr</a>
            <a href="/verein/" class="nav-link">Verein</a>
            <a href="/was-ist-wenn/" class="nav-link">Was ist wenn?</a>
          </nav>

          <details class="md:hidden relative">
            <summary
              class="cursor-pointer list-none flex items-center gap-2 text-sm font-medium text-gray-700 dark:text-gray-300 select-none p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800/60 transition-colors"
              aria-label="Navigation öffnen"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
              </svg>
            </summary>
            <nav
              aria-label="Hauptnavigation mobil"
              class="absolute right-0 top-full mt-2 w-56 bg-white dark:bg-[#1A1816] border border-gray-200 dark:border-gray-800 rounded-xl shadow-2xl py-2 z-20"
            >
              <a href="/einsaetze/" class="flex items-center px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-brand/5 hover:text-brand dark:hover:bg-brand/10 transition-colors">Einsätze</a>
              <a href="/jugendfeuerwehr/" class="flex items-center px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-brand/5 hover:text-brand dark:hover:bg-brand/10 transition-colors">Jugendfeuerwehr</a>
              <a href="/verein/" class="flex items-center px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-brand/5 hover:text-brand dark:hover:bg-brand/10 transition-colors">Verein</a>
              <a href="/was-ist-wenn/" class="flex items-center px-4 py-2.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-brand/5 hover:text-brand dark:hover:bg-brand/10 transition-colors">Was ist wenn?</a>
            </nav>
          </details>
        </div>
      </header>
    </slot>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-[#111010] dark:bg-[#0A0908] border-t-[3px] border-brand mt-2">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
          <div>
            <a href="/" class="flex items-center gap-3 mb-3 group">
              <img src="/logo-lq.webp" alt="" width="36" height="36" class="w-9 h-9 object-contain opacity-75 group-hover:opacity-100 transition-opacity" />
              <div class="leading-none">
                <span class="block text-[10px] font-bold tracking-[0.22em] uppercase text-brand">Freiwillige Feuerwehr</span>
                <span class="block text-sm font-bold text-white leading-tight">Effeltrich</span>
              </div>
            </a>
            <p class="text-xs text-gray-600">© {new Date().getFullYear()} Freiwillige Feuerwehr Effeltrich</p>
          </div>
          <nav class="flex items-center gap-6 text-sm text-gray-500" aria-label="Footer-Navigation">
            <a href="/rss.xml" class="hover:text-brand transition-colors flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <circle cx="5" cy="19" r="1"></circle>
                <path d="M4 4a16 16 0 0 1 16 16"></path>
                <path d="M4 11a9 9 0 0 1 9 9"></path>
              </svg>
              RSS
            </a>
            <a href="/impressum/" class="hover:text-brand transition-colors">Impressum</a>
          </nav>
        </div>
      </div>
    </footer>
  </body>
</html>
