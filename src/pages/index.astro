---
import Base from '../layouts/Base.astro';
import EinsatzCard from '../components/EinsatzCard.astro';
import { getCollection } from 'astro:content';

const einsaetze = await getCollection('einsaetze');
const sorted = einsaetze.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latest = sorted.slice(0, 3);
const totalEinsaetze = einsaetze.length;
---

<Base title="Startseite">
  <!-- Hero -->
  <section class="relative min-h-[82vh] flex flex-col justify-end overflow-hidden">
    <img
      src="/images/FWGH.webp"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/55 to-black/10"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/65 via-black/25 to-transparent"></div>

    <!-- 112 badge -->
    <div class="absolute bottom-20 right-4 sm:right-8 z-10 text-right select-none hidden sm:block" aria-hidden="true">
      <p class="text-[9px] font-bold tracking-[0.3em] uppercase text-white/45 mb-0.5">Notruf</p>
      <p class="font-display font-bold text-white/90 leading-none drop-shadow-2xl" style="font-size: clamp(3.5rem, 9vw, 6rem);">112</p>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-5 left-1/2 -translate-x-1/2 z-10 animate-bounce hidden sm:block" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/35">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 pb-14 pt-20 w-full">
      <p class="text-brand text-[11px] font-bold tracking-[0.35em] uppercase mb-2 animate-fade-in">
        Freiwillige Feuerwehr
      </p>
      <h1
        class="font-display font-bold text-white uppercase leading-none tracking-tight animate-fade-up"
        style="font-size: clamp(3.8rem, 11vw, 9rem); animation-delay: 0.08s;"
      >
        Effeltrich
      </h1>
      <p
        class="mt-5 text-white/70 text-[1.05rem] max-w-sm leading-relaxed animate-fade-up"
        style="animation-delay: 0.18s;"
      >
        Wir schützen und helfen – rund um die Uhr, ehrenamtlich.
      </p>
      <div class="mt-8 flex flex-wrap gap-3 animate-fade-up" style="animation-delay: 0.28s;">
        <a
          href="https://www.facebook.com/FeuerwehrEffeltrich"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-white/10 hover:bg-white/20 backdrop-blur-sm text-white text-sm font-medium transition-all border border-white/20 hover:border-white/40"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
          </svg>
          Facebook
        </a>
        <a
          href="https://www.instagram.com/feuerwehr_effeltrich/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-white/10 hover:bg-white/20 backdrop-blur-sm text-white text-sm font-medium transition-all border border-white/20 hover:border-white/40"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
          Instagram
        </a>
      </div>
    </div>
  </section>

  <!-- Status strip -->
  <div class="bg-brand">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-3 flex flex-wrap items-center gap-x-5 gap-y-1">
      <span class="text-white text-[11px] font-bold tracking-[0.18em] uppercase">HLF 10 · 42/1</span>
      <span class="text-white/35 text-xs select-none">—</span>
      <span class="text-white text-[11px] font-bold tracking-[0.18em] uppercase">MTW · 14/1</span>
      <span class="text-white/35 text-xs select-none">—</span>
      <span class="text-white text-[11px] font-bold tracking-[0.18em] uppercase">24 / 7 Bereit</span>
    </div>
  </div>

  <!-- Stats row -->
  <div class="bg-white dark:bg-[#0F0D0D] border-b border-gray-200 dark:border-gray-800/60">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-3 divide-x divide-gray-100 dark:divide-gray-800/60 py-7 text-center">
        <div class="px-4 sm:px-8">
          <p class="text-4xl sm:text-5xl font-display font-bold text-brand tabular-nums">{totalEinsaetze}</p>
          <p class="text-[10px] font-bold tracking-[0.18em] uppercase text-gray-400 dark:text-gray-600 mt-1.5">Einsätze</p>
        </div>
        <div class="px-4 sm:px-8">
          <p class="text-4xl sm:text-5xl font-display font-bold text-brand">2</p>
          <p class="text-[10px] font-bold tracking-[0.18em] uppercase text-gray-400 dark:text-gray-600 mt-1.5">Fahrzeuge</p>
        </div>
        <div class="px-4 sm:px-8">
          <p class="text-4xl sm:text-5xl font-display font-bold text-brand">24/7</p>
          <p class="text-[10px] font-bold tracking-[0.18em] uppercase text-gray-400 dark:text-gray-600 mt-1.5">Einsatzbereit</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Main content -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6">

    <!-- Weather -->
    <section class="py-12 border-b border-gray-200 dark:border-gray-800/60">
      <div class="flex items-center gap-3 mb-1">
        <div class="w-1 h-6 bg-brand rounded-sm shrink-0"></div>
        <h2 class="text-2xl font-display font-bold uppercase tracking-wide text-gray-900 dark:text-white">Aktuelle Warnungen</h2>
      </div>
      <p class="ml-4 mt-1.5 text-sm text-gray-500 dark:text-gray-400 mb-5">
        Laufend aktualisiert vom <a href="https://www.dwd.de" target="_blank" rel="noopener noreferrer" class="text-brand hover:underline">Deutschen Wetterdienst</a>.
      </p>
      <div class="overflow-hidden rounded-xl border border-gray-200 dark:border-gray-700/50">
        <img
          src="https://www.dwd.de/DWD/warnungen/warnstatus/SchilderMS.jpg"
          alt="Aktuelle Unwetterwarnungen für Bayern vom Deutschen Wetterdienst"
          width="1366"
          height="768"
          class="w-full block"
          loading="lazy"
        />
      </div>
    </section>

    <!-- Latest Einsätze -->
    <section class="py-12 border-b border-gray-200 dark:border-gray-800/60">
      <div class="flex items-center justify-between gap-4 mb-8">
        <div class="flex items-center gap-3">
          <div class="w-1 h-6 bg-brand rounded-sm shrink-0"></div>
          <h2 class="text-2xl font-display font-bold uppercase tracking-wide text-gray-900 dark:text-white">Letzte Einsätze</h2>
        </div>
        <a href="/einsaetze/" class="inline-flex items-center gap-1.5 text-sm text-brand hover:text-brand-dark font-semibold transition-colors whitespace-nowrap group">
          Alle ansehen
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </a>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {latest.map(entry => <EinsatzCard entry={entry} />)}
      </div>
    </section>

    <!-- Contact -->
    <section class="py-12">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-1 h-6 bg-brand rounded-sm shrink-0"></div>
        <h2 class="text-2xl font-display font-bold uppercase tracking-wide text-gray-900 dark:text-white">Kontakt</h2>
      </div>

      <!-- Emergency call card -->
      <a href="tel:112" class="flex items-center justify-between rounded-xl bg-brand hover:bg-brand-dark transition-colors px-6 py-5 mb-5 group">
        <div>
          <p class="text-[10px] font-bold tracking-[0.25em] uppercase text-white/60 mb-1">Im Notfall sofort anrufen</p>
          <p class="text-5xl font-display font-bold text-white leading-none">112</p>
          <p class="text-xs text-white/60 mt-1.5">Europäischer Notruf · kostenlos · rund um die Uhr</p>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/30 group-hover:text-white/50 transition-colors shrink-0" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.94a16 16 0 0 0 6.12 6.12l1.45-1.45a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path>
        </svg>
      </a>

      <div class="grid md:grid-cols-2 gap-5">
        <div class="bg-white dark:bg-[#1A1816] rounded-xl p-6 border border-gray-200 dark:border-gray-800/50">
          <p class="text-[10px] font-bold tracking-[0.22em] uppercase text-brand mb-5">Aktive Wehr</p>
          <dl class="space-y-4 text-sm">
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-[0.12em] text-gray-400 dark:text-gray-500">Kommandant</dt>
              <dd class="mt-0.5 font-semibold text-gray-900 dark:text-white">
                <a href="mailto:kdt@feuerwehr-effeltrich.de" class="hover:text-brand transition-colors">Jens Ehrhardt</a>
              </dd>
            </div>
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-[0.12em] text-gray-400 dark:text-gray-500">Stellv. Kommandantin</dt>
              <dd class="mt-0.5 font-semibold text-gray-900 dark:text-white">
                <a href="mailto:kdt@feuerwehr-effeltrich.de" class="hover:text-brand transition-colors">Antonia Gebhard-Braun</a>
              </dd>
            </div>
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-[0.12em] text-gray-400 dark:text-gray-500">Jugendwartin</dt>
              <dd class="mt-0.5 font-semibold text-gray-900 dark:text-white">
                <a href="mailto:jugend@feuerwehr-effeltrich.de" class="hover:text-brand transition-colors">Anna Heumann</a>
              </dd>
            </div>
          </dl>
        </div>

        <div class="bg-white dark:bg-[#1A1816] rounded-xl p-6 border border-gray-200 dark:border-gray-800/50">
          <p class="text-[10px] font-bold tracking-[0.22em] uppercase text-brand mb-5">Förderverein</p>
          <dl class="space-y-4 text-sm">
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-[0.12em] text-gray-400 dark:text-gray-500">1. Vorsitzender</dt>
              <dd class="mt-0.5 font-semibold text-gray-900 dark:text-white">
                <a href="mailto:vorstand@feuerwehr-effeltrich.de" class="hover:text-brand transition-colors">Peter Nögel</a>
              </dd>
            </div>
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-[0.12em] text-gray-400 dark:text-gray-500">2. Vorsitzender</dt>
              <dd class="mt-0.5 font-semibold text-gray-900 dark:text-white">
                <a href="mailto:vorstand@feuerwehr-effeltrich.de" class="hover:text-brand transition-colors">Peter Lepper</a>
              </dd>
            </div>
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-[0.12em] text-gray-400 dark:text-gray-500">Schriftführer</dt>
              <dd class="mt-0.5 font-semibold text-gray-900 dark:text-white">
                <a href="mailto:schriftfuehrer@feuerwehr-effeltrich.de" class="hover:text-brand transition-colors">Thomas Stark</a>
              </dd>
            </div>
            <div>
              <dt class="text-[10px] font-bold uppercase tracking-[0.12em] text-gray-400 dark:text-gray-500">Kassier</dt>
              <dd class="mt-0.5 font-semibold text-gray-900 dark:text-white">
                <a href="mailto:kassier@feuerwehr-effeltrich.de" class="hover:text-brand transition-colors">Christoph Steiner</a>
              </dd>
            </div>
          </dl>
        </div>
      </div>
    </section>

  </div>
</Base>
