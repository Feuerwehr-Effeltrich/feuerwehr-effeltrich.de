---
import Base from '../layouts/Base.astro';
import EinsatzCard from '../components/EinsatzCard.astro';
import { getCollection } from 'astro:content';

const einsaetze = await getCollection('einsaetze');
const latest = einsaetze
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Base title="Startseite">
  <div class="max-w-5xl mx-auto px-4">

    <section class="py-10 md:py-16">
      <div class="md:flex md:items-center md:gap-10">
        <div class="md:flex-1">
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 leading-tight">
            Freiwillige Feuerwehr Effeltrich
          </h1>
          <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
            Wir schützen und helfen – rund um die Uhr, ehrenamtlich.
          </p>
          <p class="mt-3 text-gray-600 dark:text-gray-400">
            Im Einsatz befinden sich ein <strong class="text-gray-900 dark:text-gray-200">HLF-10 (42/1)</strong> von Lentner
            sowie ein <strong class="text-gray-900 dark:text-gray-200">MTW (14/1)</strong> von Compoint.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href="https://www.facebook.com/FeuerwehrEffeltrich"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[#1877F2] text-white text-sm font-medium hover:bg-[#1565C0] transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
              </svg>
              Facebook
            </a>
            <a
              href="https://www.instagram.com/feuerwehr_effeltrich/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-gradient-to-r from-purple-500 to-pink-500 text-white text-sm font-medium hover:from-purple-600 hover:to-pink-600 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
              Instagram
            </a>
          </div>
        </div>
        <div class="mt-8 md:mt-0 md:flex-1">
          <img
            src="/images/FWGH.webp"
            alt="Gerätehaus der Feuerwehr Effeltrich mit HLF 42/1 und MTW 14/1"
            width="640"
            height="480"
            class="rounded-xl w-full object-cover shadow-sm"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <section class="py-8 border-t border-gray-200 dark:border-gray-800">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Aktuelle Warnungen</h2>
      <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
        Laufend aktualisiert vom <a href="https://www.dwd.de" target="_blank" rel="noopener noreferrer" class="text-brand hover:underline">Deutschen Wetterdienst</a>.
      </p>
      <div class="mt-4 overflow-hidden rounded-xl border border-gray-200 dark:border-gray-700">
        <img
          src="https://www.dwd.de/DWD/warnungen/warnstatus/SchilderMS.jpg"
          alt="Aktuelle Unwetterwarnungen für Bayern vom Deutschen Wetterdienst"
          width="1366"
          height="768"
          class="w-full"
          loading="lazy"
        />
      </div>
    </section>

    <section class="py-8 border-t border-gray-200 dark:border-gray-800">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Letzte Einsätze</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {latest.map(entry => <EinsatzCard entry={entry} />)}
      </div>
      <div class="mt-6">
        <a href="/einsaetze/" class="inline-flex items-center gap-2 text-brand hover:text-brand-dark font-medium transition-colors">
          Alle Einsätze ansehen
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </a>
      </div>
    </section>

    <section class="py-8 border-t border-gray-200 dark:border-gray-800">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Kontakt</h2>

      <div class="mt-6 grid md:grid-cols-2 gap-8">
        <div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3">Aktive Wehr</h3>
          <dl class="space-y-2 text-sm">
            <div>
              <dt class="text-gray-500 dark:text-gray-400">Kommandant</dt>
              <dd><a href="mailto:kdt@feuerwehr-effeltrich.de" class="text-brand hover:underline">Jens Ehrhardt</a></dd>
            </div>
            <div>
              <dt class="text-gray-500 dark:text-gray-400">Stellv. Kommandantin</dt>
              <dd><a href="mailto:kdt@feuerwehr-effeltrich.de" class="text-brand hover:underline">Antonia Gebhard-Braun</a></dd>
            </div>
            <div>
              <dt class="text-gray-500 dark:text-gray-400">Jugendwartin</dt>
              <dd><a href="mailto:jugend@feuerwehr-effeltrich.de" class="text-brand hover:underline">Anna Heumann</a></dd>
            </div>
          </dl>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3">Förderverein</h3>
          <dl class="space-y-2 text-sm">
            <div>
              <dt class="text-gray-500 dark:text-gray-400">1. Vorsitzender</dt>
              <dd><a href="mailto:vorstand@feuerwehr-effeltrich.de" class="text-brand hover:underline">Peter Nögel</a></dd>
            </div>
            <div>
              <dt class="text-gray-500 dark:text-gray-400">2. Vorsitzender</dt>
              <dd><a href="mailto:vorstand@feuerwehr-effeltrich.de" class="text-brand hover:underline">Peter Lepper</a></dd>
            </div>
            <div>
              <dt class="text-gray-500 dark:text-gray-400">Schriftführer</dt>
              <dd><a href="mailto:schriftfuehrer@feuerwehr-effeltrich.de" class="text-brand hover:underline">Thomas Stark</a></dd>
            </div>
            <div>
              <dt class="text-gray-500 dark:text-gray-400">Kassier</dt>
              <dd><a href="mailto:kassier@feuerwehr-effeltrich.de" class="text-brand hover:underline">Christoph Steiner</a></dd>
            </div>
          </dl>
        </div>
      </div>
    </section>

  </div>
</Base>
