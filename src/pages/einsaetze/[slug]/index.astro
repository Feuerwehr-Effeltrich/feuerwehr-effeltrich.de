---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../../layouts/Base.astro';

export async function getStaticPaths() {
  const einsaetze = await getCollection('einsaetze');
  return einsaetze.map(entry => ({
    params: { slug: entry.id.replace('/index.md', '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const dateFormatted = entry.data.date.toLocaleDateString('de-DE', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<Base
  title={entry.data.title}
  description={entry.data.description}
  ogImage={entry.data.image?.src}
>
  <article class="max-w-3xl mx-auto px-4 py-10">
    <nav class="mb-6 text-sm text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
      <a href="/einsaetze/" class="hover:text-brand transition-colors">Einsätze</a>
      <span class="mx-2" aria-hidden="true">›</span>
      <span class="text-gray-900 dark:text-gray-100">{entry.data.title}</span>
    </nav>

    <header>
      <time datetime={entry.data.date.toISOString()} class="text-sm font-medium text-brand uppercase tracking-wide">
        {dateFormatted}
      </time>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 dark:text-gray-100 leading-tight">
        {entry.data.title}
      </h1>
      {entry.data.description && (
        <p class="mt-2 text-lg text-gray-600 dark:text-gray-400">{entry.data.description}</p>
      )}
    </header>

    <div class="mt-8 prose prose-gray dark:prose-invert max-w-none
      prose-img:rounded-xl prose-img:shadow-sm prose-img:w-full
      prose-a:text-brand prose-a:no-underline hover:prose-a:underline
    ">
      <Content />
    </div>

    <div class="mt-10 pt-6 border-t border-gray-200 dark:border-gray-800">
      <a href="/einsaetze/" class="inline-flex items-center gap-2 text-brand hover:text-brand-dark font-medium transition-colors text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
        Zurück zu allen Einsätzen
      </a>
    </div>
  </article>
</Base>
