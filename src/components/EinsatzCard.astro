---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'einsaetze'>;
}

const { entry } = Astro.props;
const slug = entry.id.replace('/index.md', '');

const dateFormatted = entry.data.date.toLocaleDateString('de-DE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const typeCode = slug.replace(/^\d{4}-\d{2}-\d{2}-/, '');
const typeLabel = typeCode.startsWith('b') ? 'Brand'
  : typeCode === 'abc' ? 'ABC'
  : typeCode === 'thlu' ? 'THL · Unwetter'
  : typeCode === 'thlp' ? 'THL · Person'
  : typeCode === 'thlr' ? 'THL · Verkehr'
  : 'THL';
const typeCls = typeCode.startsWith('b')
  ? 'bg-orange-500/15 text-orange-600 dark:text-orange-400'
  : typeCode === 'abc'
  ? 'bg-yellow-500/15 text-yellow-700 dark:text-yellow-400'
  : 'bg-blue-500/15 text-blue-700 dark:text-blue-400';
---

<article class="group bg-white dark:bg-[#1A1816] rounded-xl overflow-hidden border border-gray-200 dark:border-gray-800/50 hover:border-gray-300 dark:hover:border-gray-700 hover:-translate-y-0.5 hover:shadow-lg dark:hover:shadow-black/50 transition-all duration-300">
  {entry.data.image ? (
    <a href={`/einsaetze/${slug}/`} tabindex="-1" aria-hidden="true" class="block overflow-hidden aspect-video">
      <Image
        src={entry.data.image}
        alt=""
        width={600}
        height={338}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
        loading="lazy"
      />
    </a>
  ) : (
    <a href={`/einsaetze/${slug}/`} tabindex="-1" aria-hidden="true" class="block aspect-video bg-gray-100 dark:bg-gray-800/50 flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-300 dark:text-gray-600" aria-hidden="true">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
        <polyline points="9 22 9 12 15 12 15 22"></polyline>
      </svg>
    </a>
  )}
  <div class="p-4">
    <div class="flex items-center gap-2 flex-wrap">
      <time datetime={entry.data.date.toISOString()} class="inline-block text-[10px] font-bold tracking-[0.1em] uppercase bg-brand text-white px-2 py-0.5 rounded">
        {dateFormatted}
      </time>
      <span class={`inline-block text-[10px] font-bold tracking-[0.1em] uppercase px-2 py-0.5 rounded ${typeCls}`}>
        {typeLabel}
      </span>
    </div>
    <h2 class="mt-2 text-[0.925rem] font-bold leading-snug">
      <a href={`/einsaetze/${slug}/`} class="text-gray-900 dark:text-white hover:text-brand dark:hover:text-brand transition-colors">
        {entry.data.title}
      </a>
    </h2>
    {entry.data.description && (
      <p class="mt-1.5 text-sm text-gray-500 dark:text-gray-400 line-clamp-2 leading-relaxed">{entry.data.description}</p>
    )}
  </div>
</article>
